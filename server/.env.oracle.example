# Oracle 서버 베이스 브랜치(claude/oracle-server-setup-c1LNU) 용 환경변수
# 사용법: cp server/.env.oracle.example server/.env.oracle
#         DB_PASS / JWT_SECRET 값을 실제 값으로 수정
#
# post-checkout 훅이 브랜치 전환 시 이 파일을 server/.env 로 심볼릭 링크합니다.

DB_HOST=localhost
DB_PORT=3306
DB_USER=jobapp
DB_PASS=your_strong_password_here
DB_NAME=JOB
JWT_SECRET=your_random_secret_key_here
JWT_EXPIRE_HOURS=24
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# OAuth (소셜 로그인)
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_BASE=http://localhost:8000

# SMTP (회사 이메일 인증)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
