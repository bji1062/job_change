[Unit]
Description=Job Choice — expire stale badges (official → est when EXPIRES_DTM passed)
After=network.target mysql.service
# jobchoice.service 가 반드시 실행되어 있을 필요는 없음 — DB 만 있으면 됨

[Service]
Type=oneshot
User=ubuntu
WorkingDirectory=/home/ubuntu/job_change/server
Environment=PATH=/home/ubuntu/job_change/server/venv/bin
ExecStart=/home/ubuntu/job_change/server/venv/bin/python3 /home/ubuntu/job_change/server/scripts/expire_badges.py
StandardOutput=journal
StandardError=journal
