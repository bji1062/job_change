variable "tenancy_ocid" {
  description = "OCI Tenancy OCID"
}

variable "user_ocid" {
  description = "OCI User OCID"
}

variable "fingerprint" {
  description = "API signing key fingerprint"
}

variable "private_key_path" {
  description = "Path to OCI API private key file"
}

variable "region" {
  default     = "ap-seoul-1"
  description = "OCI region"
}

variable "compartment_ocid" {
  description = "Compartment OCID"
}

variable "ssh_public_key" {
  description = "SSH public key content for instance access"
}

variable "instance_shape" {
  default     = "VM.Standard.A1.Flex"
  description = "Compute instance shape (Always Free ARM)"
}

variable "instance_ocpus" {
  default     = 2
  description = "Number of OCPUs"
}

variable "instance_memory_gb" {
  default     = 12
  description = "Memory in GB"
}

variable "my_ip_cidr" {
  description = "Your IP CIDR for SSH access (e.g. 1.2.3.4/32)"
}
