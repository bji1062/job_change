[client]
port                                    = 3306
socket                                  = /tmp/mysql.sock
default-character-set                   = utf8mb4

[mysqld_safe]
open_files_limit                        = 65536

[mysqld]
# ── 기본 설정 ──
default_authentication_plugin           = mysql_native_password
socket                                  = /tmp/mysql.sock
datadir                                 = /usr/local/mysql/data
basedir                                 = /usr/local/mysql
user                                    = mysql
port                                    = 3306
bind-address                            = 127.0.0.1
pid-file                                = /usr/local/mysql/data/mysqld.pid
skip-external-locking
skip_name_resolve                       = ON
symbolic-links                          = 0

# ── SQL 모드 ──
sql_mode                                = ONLY_FULL_GROUP_BY,STRICT_TRANS_TABLES,NO_ZERO_IN_DATE,NO_ZERO_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION
transaction-isolation                   = READ-COMMITTED
explicit_defaults_for_timestamp         = TRUE
autocommit                              = ON
event_scheduler                         = ON

# ── 문자셋 (utf8mb4 — 한글 완벽 지원) ──
character-set-client-handshake          = FALSE
character-set-server                    = utf8mb4
collation-server                        = utf8mb4_unicode_ci
init_connect                            = 'SET NAMES utf8mb4'

# ── 커넥션 (aiomysql pool max=10 + 관리용 여유) ──
max_connections                         = 30
max_connect_errors                      = 50
thread_cache_size                       = 8
thread_handling                         = one-thread-per-connection
wait_timeout                            = 600
interactive_timeout                     = 600

# ── 버퍼 (12GB RAM 기준 — OS·Python·Nginx 메모리 확보) ──
max_allowed_packet                      = 64M
table_open_cache                        = 2048
table_definition_cache                  = 1024
sort_buffer_size                        = 512K
read_buffer_size                        = 256K
read_rnd_buffer_size                    = 512K
join_buffer_size                        = 512K
tmp_table_size                          = 128M
max_heap_table_size                     = 128M
bulk_insert_buffer_size                 = 16M

# ── InnoDB (12GB RAM 핵심 — 전체 메모리의 ~33%) ──
default-storage-engine                  = InnoDB
innodb_buffer_pool_size                 = 4G
innodb_buffer_pool_instances            = 4
innodb_data_file_path                   = ibdata1:10M:autoextend
innodb_log_file_size                    = 512M
innodb_log_buffer_size                  = 64M
innodb_flush_log_at_trx_commit          = 2
innodb_flush_method                     = O_DIRECT
innodb_file_per_table                   = 1
innodb_write_io_threads                 = 4
innodb_read_io_threads                  = 4
innodb_thread_concurrency               = 4
innodb_lock_wait_timeout                = 120
innodb_max_dirty_pages_pct              = 75
innodb_io_capacity                      = 200
innodb_doublewrite                      = ON
innodb_open_files                       = 2048

# ── MyISAM (최소 설정 — InnoDB 기본 사용) ──
key_buffer_size                         = 128K
myisam_sort_buffer_size                 = 128K

# ── 로그 ──
log_error                               = /usr/local/mysql/data/error.log
log_timestamps                          = SYSTEM
slow_query_log                          = ON
slow_query_log_file                     = /usr/local/mysql/data/slow.log
long_query_time                         = 0.5

# ── 보안 ──
local_infile                            = 0
secure_file_priv                        = ''
mysqlx                                  = 0

# ── 바이너리 로그 (백업/복구용 최소 설정) ──
log-bin                                 = /usr/local/mysql/data/bin-log
sync_binlog                             = 1
max_binlog_size                         = 100M
binlog_expire_logs_seconds              = 259200

[mysqldump]
default-character-set                   = utf8mb4
max_allowed_packet                      = 64M

[mysql]
default-character-set                   = utf8mb4
no-auto-rehash
prompt                                  = 'jobchoice \\d> '

[myisamchk]
key_buffer_size                         = 16M
sort_buffer_size                        = 16M
