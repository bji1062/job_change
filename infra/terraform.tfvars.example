# AWS 인증은 환경변수 또는 ~/.aws/credentials 사용
# export AWS_ACCESS_KEY_ID="..."
# export AWS_SECRET_ACCESS_KEY="..."

# 리전
region = "ap-northeast-2"

# SSH 공개 키 (인스턴스 접속용)
ssh_public_key = "ssh-rsa AAAA..."

# SSH 접근 허용 IP (본인 IP)
my_ip_cidr = "0.0.0.0/0"

# 인스턴스 스펙 (기본값)
# instance_type  = "t4g.small"
# volume_size_gb = 50
